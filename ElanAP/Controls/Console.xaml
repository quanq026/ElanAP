<UserControl x:Class="ElanAP.Controls.Console"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ElanAP.Controls"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="450">
    <Grid>
        <ScrollViewer x:Name="Scroller" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="Buffer" Padding="2"
                     Foreground="White" Background="Black"
                     FontFamily="Lucida Console"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     BorderThickness="0"
                     AcceptsReturn="True">
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy all" Click="CopyAll"/>
                        <MenuItem Header="Copy selection" Click="CopySelection"/>
                        <MenuItem Header="Clear" Click="Clear"/>
                    </ContextMenu>
                </TextBox.ContextMenu>
            </TextBox>
        </ScrollViewer>
    </Grid>
</UserControl>
